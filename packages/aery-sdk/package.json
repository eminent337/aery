{
	"name": "@aryee337/aery-sdk",
	"version": "0.2.1",
	"description": "Official Aery Plugin SDK — build extensions, tools, and commands for the Aery OS",
	"type": "module",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"author": "Aryee",
	"license": "MIT",
	"homepage": "https://aery.dev",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/eminent337/aery.git",
		"directory": "packages/aery-sdk"
	},
	"bugs": {
		"url": "https://github.com/eminent337/aery/issues"
	},
	"keywords": ["aery", "aery-sdk", "plugin", "extension", "agent", "sdk"],
	"engines": { "bun": ">=1.3.14" },
	"files": ["src"],
	"scripts": {
		"check": "biome check . && bun run check:types",
		"check:types": "tsgo -p tsconfig.json --noEmit",
		"lint": "biome lint .",
		"fix": "biome check --write --unsafe .",
		"fmt": "biome format --write ."
	},
	"devDependencies": {
		"@types/bun": "catalog:"
	},
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		},
		"./tools": {
			"types": "./src/tools.ts",
			"import": "./src/tools.ts"
		},
		"./events": {
			"types": "./src/events.ts",
			"import": "./src/events.ts"
		},
		"./swarm": {
			"types": "./src/swarm.ts",
			"import": "./src/swarm.ts"
		},
		"./*": {
			"types": "./src/*.ts",
			"import": "./src/*.ts"
		}
	}
}
