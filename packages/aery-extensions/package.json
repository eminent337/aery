{
  "type": "module",
  "name": "@aryee337/aery-extensions",
  "version": "0.3.6",
  "description": "Native Extension Marketplace for Aery",
  "homepage": "https://aery.dev",
  "author": "eminent337",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eminent337/aery.git",
    "directory": "packages/aery-extensions"
  },
  "scripts": {
    "check": "biome check . && bun run check:types",
    "check:types": "tsgo -p tsconfig.json --noEmit",
    "lint": "biome lint .",
    "fix": "biome check --write --unsafe .",
    "fmt": "biome format --write ."
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "dependencies": {
    "@aryee337/aery": "workspace:*",
    "@aryee337/aery-tui": "workspace:*",
    "@aryee337/aery-utils": "workspace:*",
    "@sinclair/typebox": "0.34.49",
    "@xenova/transformers": "2.17.2",
    "glob": "13.0.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "playwright": "1.60.0"
  },
  "peerDependencies": {
    "@aryee337/aery": "workspace:*"
  },
  "engines": {
    "bun": ">=1.3.14"
  },
  "files": [
    "src",
    "registry.json",
    "README.md"
  ]
}
