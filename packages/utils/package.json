{
  "type": "module",
  "name": "@aryee337/aery-utils",
  "version": "0.3.8",
  "description": "Shared utilities for aery packages",
  "homepage": "https://aery.dev",
  "author": "aryee337",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eminent337/aery.git",
    "directory": "packages/utils"
  },
  "bugs": {
    "url": "https://github.com/eminent337/aery/issues"
  },
  "keywords": [
    "utilities",
    "cli",
    "logging",
    "streams"
  ],
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "check": "biome check . && bun run check:types",
    "check:types": "tsgo -p tsconfig.json --noEmit",
    "lint": "biome lint .",
    "test": "bun test --parallel --timeout 30000",
    "fix": "biome check --write --unsafe .",
    "fmt": "biome format --write ."
  },
  "dependencies": {
    "@aryee337/aery-engine": "workspace:*",
    "beautiful-mermaid": "catalog:",
    "handlebars": "catalog:",
    "winston": "catalog:",
    "winston-daily-rotate-file": "catalog:"
  },
  "devDependencies": {
    "@types/bun": "catalog:"
  },
  "engines": {
    "bun": ">=1.3.14"
  },
  "files": [
    "src"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./*": {
      "types": "./src/*.ts",
      "import": "./src/*.ts"
    },
    "./*.js": "./src/*.ts"
  }
}
