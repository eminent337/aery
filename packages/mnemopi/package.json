{
  "type": "module",
  "name": "@aryee337/aery-mnemopi",
  "version": "0.3.4",
  "description": "Local SQLite memory engine for Aery agents",
  "homepage": "https://aery.dev",
  "author": "aryee337",
  "contributors": [
    "Abdias J"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eminent337/aery.git",
    "directory": "packages/mnemopi"
  },
  "bugs": {
    "url": "https://github.com/eminent337/aery/issues"
  },
  "keywords": [
    "memory",
    "sqlite",
    "agent",
    "embeddings",
    "mcp"
  ],
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "bin": {
    "mnemopi": "src/cli.ts"
  },
  "scripts": {
    "check": "biome check . && bun run check:types",
    "check:types": "tsgo -p tsconfig.json --noEmit",
    "lint": "biome lint .",
    "test": "bun test --parallel",
    "fix": "biome check --write --unsafe .",
    "fmt": "biome format --write ."
  },
  "dependencies": {
    "@aryee337/aery-ai": "workspace:*",
    "@aryee337/aery-utils": "workspace:*",
    "fastembed": "catalog:",
    "lru-cache": "catalog:",
    "onnxruntime-node": "catalog:"
  },
  "devDependencies": {
    "@types/bun": "catalog:"
  },
  "engines": {
    "bun": ">=1.3.14"
  },
  "files": [
    "src",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./core": {
      "types": "./src/core/index.ts",
      "import": "./src/core/index.ts"
    },
    "./beam": {
      "types": "./src/core/beam/index.ts",
      "import": "./src/core/beam/index.ts"
    },
    "./diagnose": {
      "types": "./src/diagnose.ts",
      "import": "./src/diagnose.ts"
    },
    "./mcp": {
      "types": "./src/mcp-tools.ts",
      "import": "./src/mcp-tools.ts"
    },
    "./cli": {
      "types": "./src/cli.ts",
      "import": "./src/cli.ts"
    }
  }
}
